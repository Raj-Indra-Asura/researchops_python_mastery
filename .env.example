# Environment variables — copy to .env and fill in values
# Do NOT commit .env to version control

# --- App ---
RESEARCHOPS_ENV=development
RESEARCHOPS_LOG_LEVEL=INFO

# --- Database ---
RESEARCHOPS_DB_PATH=data/researchops.db

# --- Embeddings (Week 13+) ---
# RESEARCHOPS_EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- LLM / RAG (Week 17+) ---
# OPENAI_API_KEY=sk-...
# RESEARCHOPS_LLM_MODEL=gpt-4o-mini

# --- API (Week 14+) ---
RESEARCHOPS_API_HOST=0.0.0.0
RESEARCHOPS_API_PORT=8000

# --- Worker (Week 16+) ---
RESEARCHOPS_WORKER_CONCURRENCY=4
